{
    "version": 4,
    "configurePresets": [
        {
            "name": "windows-environment",
            "hidden": true,
            "environment": {
                "DEPS_ROOT"                     : "C:/MoonRay/installs",
                "BUILD_DIR"                     : "C:/MoonRay/build",
                "VCPKG_ROOT"                    : "C:/vcpkg",
                "Boost_ROOT"                    : "$env{DEPS_ROOT}",
                "CppUnit_ROOT"                  : "$env{DEPS_ROOT}",
                "ISPC"                          : "$env{DEPS_ROOT}/bin/ispc.exe",
                "JsonCpp_ROOT"                  : "$env{DEPS_ROOT}",
                "Libcurl_ROOT"                  : "$env{DEPS_ROOT}",
                "Log4cplus_ROOT"                : "$env{DEPS_ROOT}",
                "LUA_DIR"                       : "$env{DEPS_ROOT}",
                "OpenSubDiv_ROOT"               : "$env{DEPS_ROOT}",
                "OpenVDB_ROOT"                  : "$env{DEPS_ROOT}",
                "OPTIX_ROOT"                    : "$env{DEPS_ROOT}/optix",
                "PXR_USD_LOCATION"              : "$env{DEPS_ROOT}",
                "PXR_INCLUDE_DIRS"              : "$env{DEPS_ROOT}/include",
                "Random123_ROOT"                : "$env{DEPS_ROOT}",
                "ZLIB_ROOT"                     : "$env{DEPS_ROOT}",
                "OIIO_PYTHON"                   : "$env{DEPS_ROOT}/lib/site-packages"
            },
            "cacheVariables": {
                "CMAKE_PREFIX_PATH"             : "$env{DEPS_ROOT}",
                "CMAKE_TOOLCHAIN_FILE"          : "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
                "VCPKG_TARGET_TRIPLET"          : "x64-windows",
                "PYTHON_EXECUTABLE"             : "python",
                "BOOST_PYTHON_COMPONENT_NAME"   : "python3",
                "ABI_VERSION"                   : "0",
                "BUILD_QT_APPS"                 : "OFF"
            }
        },
        {
            "name": "windows-environment-nocuda",
            "hidden": true,
            "inherits": "windows-environment",
            "cacheVariables": {
                "MOONRAY_USE_CUDA" : "OFF"
            }
        },
        {
            "name": "windows-release",
            "displayName": "Windows Release",
            "inherits": "windows-environment",
            "binaryDir": "$env{BUILD_DIR}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE"       : "Release",
                "CMAKE_INSTALL_PREFIX"   : "C:/MoonRay/installs/openmoonray"
            },
            "generator": "Ninja"
        },
        {
            "name": "windows-release-nocuda",
            "displayName": "Windows Release (no CUDA)",
            "inherits": "windows-environment-nocuda",
            "binaryDir": "$env{BUILD_DIR}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE"       : "Release",
                "CMAKE_INSTALL_PREFIX"   : "C:/MoonRay/installs/openmoonray"
            },
            "generator": "Ninja"
        }
    ],
    "buildPresets": [
        {
            "name": "windows-release",
            "displayName": "Windows Release",
            "configurePreset": "windows-release",
            "configuration": "Release",
            "targets": ["install"]
        },
        {
            "name": "windows-release-nocuda",
            "displayName": "Windows Release (no CUDA)",
            "configurePreset": "windows-release-nocuda",
            "configuration": "Release",
            "targets": ["install"]
        }
    ]
}
